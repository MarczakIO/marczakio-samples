{
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "type": "AdaptiveCard",
    "version": "1.0",
    "body": [
        {
            "type": "TextBlock",
            "text": "I'm done! 🥳🙌"
        },
        {
            "type": "TextBlock",
            "text": "Your resource group **@{body('Parse_JSON_-_Temp_Variables')?['groupName']}** is completed.",
            "wrap": true
        },
        {
            "type": "TextBlock",
            "text": "But important stuff first\n* ⚠️ Do NOT use this for project purposes, **only learning**.\n* ⚠️ **No client data** should be placed in sandbox environment at any time.\n* ⏳ Group will automatically be **deleted after 12 hours**!",
            "wrap": true
        },
        {
            "type": "TextBlock",
            "text": "Click below to open your group in Azure Portal. 👇",
            "wrap": true
        }
    ],
    "actions": [
        {
            "type": "Action.OpenUrl",
            "title": "Open Resource Group",
            "url": "https://portal.azure.com/#@{concat('@', variables('SandboxTenantName'))}/resource/subscriptions/@{variables('SandboxSubscriptionId')}/resourceGroups/@{body('Parse_JSON_-_Temp_Variables')?['groupName']}/overview",
            "id": "open-rg"
        }
    ]
}
